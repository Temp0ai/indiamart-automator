# Indiamart Inquiry Automator — Environment Variables
# Copy this file to .env and fill in your values.

# ── Gmail IMAP (no Google Cloud needed) ──────────────────────────────────────
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and your device
# 3. Copy the 16-character app password below
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Company Info (used in message templates) ─────────────────────────────────
COMPANY_NAME=Your Company Name
COMPANY_PHONE=+91-9876543210

# ── WhatsApp Settings ────────────────────────────────────────────────────────
# Daily sending limit (keep low to avoid blocks)
WA_DAILY_LIMIT=50
